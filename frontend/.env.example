# Frontend environment variables (Vite reads VITE_-prefixed vars).
# Copy to .env.local for local overrides.

# Backend origin in production (e.g. https://trialfinder-api.up.railway.app).
# Leave blank in local dev — vite.config.js proxies /api to localhost:8000.
VITE_API_BASE_URL=

# Set to "true" to develop the UI against built-in mock data (no backend needed).
VITE_USE_MOCK=false
