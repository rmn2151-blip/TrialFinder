# Linkup API
LINKUP_API_KEY=your_linkup_api_key_here

# Anthropic Claude API
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# App settings
MOCK_LINKUP=false          # Set to "true" during dev to skip real Linkup calls
LINKUP_DEPTH=standard      # "standard" for dev, "deep" for demos
MAX_TRIALS_RETURNED=5
RATE_LIMIT_PER_MINUTE=10   # Protect your $20 budget

# Watchlist + email alerts
# DATABASE_URL: defaults to a local SQLite file (backend/trialfinder.db).
# For persistence in production, point at Postgres, e.g.
#   postgresql+psycopg://user:pass@host:5432/trialfinder
DATABASE_URL=

# Resend (https://resend.com) for nightly change alerts. If unset, the app
# logs the email instead of sending — fine for local dev and demos.
RESEND_API_KEY=
EMAIL_FROM=TrialFinder <onboarding@resend.dev>

# Optional shared secret to protect POST /api/watchlist/check. If set, the
# nightly job/cron must pass it as the X-Cron-Token header.
CRON_TOKEN=

# Authentication — sign JWTs. MUST be set to a long random string in prod.
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=
JWT_TTL_DAYS=7
